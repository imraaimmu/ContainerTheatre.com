# Container Theatre v1.0 - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# RAZORPAY CONFIGURATION (Required for payments)
# ===========================================

# Get your keys from: https://dashboard.razorpay.com/app/keys
# For testing, use test mode keys (start with rzp_test_)
# For production, use live mode keys (start with rzp_live_)

# Public key (exposed to browser) - used in checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Secret key (server-side only) - used for order creation & verification
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# ===========================================
# CONTACT INFORMATION (Update before launch)
# ===========================================

NEXT_PUBLIC_PHONE=+919876543210
NEXT_PUBLIC_WHATSAPP=919876543210
NEXT_PUBLIC_EMAIL=book@containertheatre.in
NEXT_PUBLIC_INSTAGRAM=containertheatre.v1

# ===========================================
# OPTIONAL: GOOGLE MAPS
# ===========================================

NEXT_PUBLIC_GOOGLE_MAPS_URL=https://maps.google.com/?q=nagercoil

# ===========================================
# OPTIONAL: FIREBASE (for database/notifications)
# ===========================================

# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# ===========================================
# OPTIONAL: MSG91/TWILIO (for SMS notifications)
# ===========================================

# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=
# MSG91_TEMPLATE_ID=
